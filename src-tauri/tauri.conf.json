{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "imechen",
  "version": "0.1.0",
  "identifier": "com.manomekun.imechen",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "imechen",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Utility",
    "shortDescription": "Offline image/video converter",
    "longDescription": "A desktop application for converting and compressing images and videos completely offline. Supports JPEG, PNG, GIF, WebP, BMP, MP4, MOV, AVI, WebM, and animation creation.",
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
